# ============================================
# Variables de entorno - Supabase
# ============================================
# Copiar como .env.local y completar con valores de Supabase DEV.
#
# Obtener desde: Supabase Dashboard > Settings > API Keys
#
# IMPORTANTE:
# - Este archivo apunta al proyecto DEV (no prod)
# - Las env vars de prod estan en Vercel (no tocar)
# - Este archivo NO se sube a Git (.gitignore lo excluye)

# URL del proyecto Supabase (ej: https://abcdefghij.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO_DEV.supabase.co

# Publishable key (antes llamada "anon key") - segura para el frontend
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Secret key (antes llamada "service_role key") - solo para API routes y simulador
# NUNCA exponer en codigo client-side
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
