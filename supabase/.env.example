# ============================================
# Supabase - env vars para migraciones
# ============================================
# Copiar como .env.dev o .env.prod y completar valores
# Estos archivos NO se suben a Git (.gitignore los excluye)

# Connection string de Postgres
# Formato: postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
#
# Obtener desde: Supabase Dashboard > Settings > Database > Connection string
#   - Elegir "URI" o "Transaction pooler"
#   - Reemplazar [YOUR-PASSWORD] por el database password que definiste al crear el proyecto
export DATABASE_URL="postgresql://postgres.XXX:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres"
